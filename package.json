{
  "name": "prosperity-visualizer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c auto \"vite --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on http://127.0.0.1:5173 && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "verify:dist": "node electron/verify-dist.cjs",
    "dist": "npm run build && npm run verify:dist && electron-builder --mac",
    "dist:mac": "npm run build && npm run verify:dist && electron-builder --mac dmg zip",
    "dist:mac:unsigned": "npm run build && npm run verify:dist && electron-builder --mac dmg --config.mac.identity=null",
    "diagnose:packaged": "node electron/run-packaged-diagnostic.cjs"
  },
  "build": {
    "appId": "com.prosperity.visualizer",
    "productName": "Prosperity Visualizer",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.finance",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "afterSign": "electron/notarize.cjs",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "plotly.js-dist-min": "^3.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-plotly.js": "^2.6.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-plotly.js": "^2.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  }
}
